{
  "name": "posh-cuisine-booking-system",
  "version": "1.0.0",
  "description": "Premium dining reservation system for Posh Cuisine restaurant",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "test:unit": "jest tests/unit --forceExit",
    "test:integration": "jest tests/integration --forceExit",
    "docker:build": "docker build -t posh-cuisine-app .",
    "docker:run": "docker run -p 5000:5000 --env-file .env posh-cuisine-app"
  },
  "keywords": [
    "restaurant",
    "booking",
    "reservation"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.4",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "prettier": "^3.0.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "mongodb-memory-server": "^9.1.6"
  }
}
